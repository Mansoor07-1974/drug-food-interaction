# MolGuard Backend Configuration
# Copy this to .env and adjust as needed

# ── Server ──────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
RELOAD=true

# ── Model ───────────────────────────────────────────────────────────────────
MODEL_PATH=model_artifacts/full_checkpoint.pt
MODEL_CONFIG_PATH=model_artifacts/model_config.json
PREDICTION_THRESHOLD=0.5

# ── Dataset paths ────────────────────────────────────────────────────────────
DRUG_CSV=../datasets/drug_interactions.csv
FOOD_CSV=../datasets/food_constituents.csv

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_MAX_ENTRIES=500
CACHE_TTL_DAYS=7

# ── PubChem API ──────────────────────────────────────────────────────────────
PUBCHEM_TIMEOUT=10

# ── CORS ─────────────────────────────────────────────────────────────────────
# Add your frontend URL here if deploying
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
